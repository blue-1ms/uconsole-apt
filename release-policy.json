{
  "schema": "uconsole-apt-release-policy-v2",
  "repository": "blue-1ms/uconsole-apt",
  "immutable": true,
  "resume_requires_exact_assets": true,
  "direct_repository": {
    "branch": "gh-pages",
    "url": "https://blue-1ms.github.io/uconsole-apt",
    "suites": ["stable", "candidate"],
    "candidate_enabled_by_default": false,
    "signed_inrelease_required": true
  },
  "release_tag_patterns": [
    "<upstream>-candidate.<NN>",
    "<upstream>-stable",
    "platform-<version>-stable"
  ],
  "required_channel_assets": [
    "CHANNEL-RECEIPT.json",
    "SHA256SUMS",
    "uconsole-archive-keyring.asc",
    "dists/stable/InRelease",
    "dists/candidate/InRelease"
  ],
  "forbidden_publish_options": [
    "--clobber",
    "floating-latest-tag"
  ]
}
